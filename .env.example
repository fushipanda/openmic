# в”Ђв”Ђ LOCAL-FIRST (fully private, no cloud) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Run `openmic transcribe` or `openmic model` to switch interactively.
# To go fully offline, set both:
#   TRANSCRIPTION_BACKEND=local   (whisper.cpp вЂ” no ElevenLabs calls)
#   LLM_PROVIDER=ollama           (Ollama вЂ” no cloud LLM or embeddings)
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

# Transcription backend: "elevenlabs" (default, cloud) or "local" (whisper.cpp, no cloud)
# TRANSCRIPTION_BACKEND=local

# Local whisper model (only used when TRANSCRIPTION_BACKEND=local)
# WHISPER_MODEL=small.en    # tiny.en, base.en, small.en, medium.en, large-v3, large-v3-turbo

# webrtcvad for speech-boundary detection (local backend only)
# Requires: pip install "openmic[local]"
# Set to "false" to revert to fixed-interval transcription
# WHISPER_VAD_ENABLED=true

# VAD aggressiveness (0вЂ“3). Higher = more aggressive silence filtering. Default: 2
# WHISPER_VAD_AGGRESSIVENESS=2

# Milliseconds of silence before a speech segment is flushed to Whisper. Default: 600
# WHISPER_VAD_SILENCE_MS=600

# ElevenLabs API key (required when TRANSCRIPTION_BACKEND=elevenlabs or unset)
ELEVENLABS_API_KEY=

# ElevenLabs Scribe model (default: scribe_v1; set scribe_v1_experimental to try beta)
# ELEVENLABS_SCRIBE_MODEL=scribe_v1

# LLM provider for RAG and notes (anthropic, openai, gemini, openrouter)
LLM_PROVIDER=anthropic

# LLM model override (set automatically by /model command)
# LLM_MODEL=claude-3-5-sonnet-20241022

# Anthropic API key (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenAI API key (required for embeddings with all cloud LLM providers)
# Not required when LLM_PROVIDER=ollama вЂ” embeddings are local (nomic-embed-text)
OPENAI_API_KEY=

# Google Gemini API key (required when LLM_PROVIDER=gemini)
# GEMINI_API_KEY=

# OpenRouter API key (required when LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=

# Ollama settings (used when LLM_PROVIDER=ollama)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text   # Model for local embeddings (must be pulled in Ollama)

# Enable extended thinking for Anthropic models (true/false)
# LLM_EXTENDED_THINKING=false
