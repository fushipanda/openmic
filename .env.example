# ElevenLabs API key (required for transcription)
ELEVENLABS_API_KEY=

# ElevenLabs Scribe model (default: scribe_v1; set scribe_v1_experimental to try beta)
# ELEVENLABS_SCRIBE_MODEL=scribe_v1

# LLM provider for RAG and notes (anthropic, openai, gemini, openrouter)
LLM_PROVIDER=anthropic

# LLM model override (set automatically by /model command)
# LLM_MODEL=claude-3-5-sonnet-20241022

# Anthropic API key (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenAI API key (always required for embeddings, even with LLM_PROVIDER=anthropic)
OPENAI_API_KEY=

# Google Gemini API key (required when LLM_PROVIDER=gemini)
# GEMINI_API_KEY=

# OpenRouter API key (required when LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=

# Enable extended thinking for Anthropic models (true/false)
# LLM_EXTENDED_THINKING=false
