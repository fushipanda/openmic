# ElevenLabs API key (required for transcription)
ELEVENLABS_API_KEY=

# LLM provider for RAG and notes (anthropic or openai)
LLM_PROVIDER=anthropic

# Anthropic API key (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenAI API key (always required for embeddings, even with LLM_PROVIDER=anthropic)
OPENAI_API_KEY=
