# ── TRANSCRIPTION ─────────────────────────────────────────────────────────────
# Transcription is handled locally via whisper.cpp — no API key required.
# Audio never leaves your machine.
# ──────────────────────────────────────────────────────────────────────────────

# Whisper model to use for transcription (auto-downloads on first run)
# WHISPER_MODEL=small.en    # tiny.en, base.en, small.en, medium.en, large-v3, large-v3-turbo

# webrtcvad for speech-boundary detection (reduces realtime latency from ~10s to ~1-3s)
# Requires: pip install "openmic[local]"
# Set to "false" to revert to fixed-interval transcription
# WHISPER_VAD_ENABLED=true

# VAD aggressiveness (0–3). Higher = more aggressive silence filtering. Default: 2
# WHISPER_VAD_AGGRESSIVENESS=2

# Milliseconds of silence before a speech segment is flushed to Whisper. Default: 600
# WHISPER_VAD_SILENCE_MS=600


# ── LLM — for /query and /notes ───────────────────────────────────────────────
# Required for RAG querying and notes generation.
# Not needed if you only use openmic for transcription.
# ──────────────────────────────────────────────────────────────────────────────

# LLM provider (anthropic, openai, gemini, openrouter, ollama)
LLM_PROVIDER=anthropic

# LLM model override (set automatically by /model command)
# LLM_MODEL=claude-3-5-sonnet-20241022

# Anthropic API key (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenAI API key (required for embeddings with all cloud LLM providers)
# Not required when LLM_PROVIDER=ollama — embeddings are local (nomic-embed-text)
OPENAI_API_KEY=

# Google Gemini API key (required when LLM_PROVIDER=gemini)
# GEMINI_API_KEY=

# OpenRouter API key (required when LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=

# Ollama settings (used when LLM_PROVIDER=ollama — fully private, no cloud)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text   # Model for local embeddings (must be pulled in Ollama)

# Enable extended thinking for Anthropic models (true/false)
# LLM_EXTENDED_THINKING=false
